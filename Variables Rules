from flask import Flask

app=Flask(__name__)

@app.route("/")
def welcome():
    return "welcome"

@app.route("/success/<int:score>")
def success(score):
    return "The person passed score is:"+str(score)

@app.route("/fail/<int:score>")
def score(score):
    return "The person passed score is:"+str(score)

if __name__=="__main__":
    app.run(debug=True)
